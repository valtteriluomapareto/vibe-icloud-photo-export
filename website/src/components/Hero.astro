---
const base = import.meta.env.BASE_URL;
---

<section class="hero">
	<div class="hero-content">
		<img
			src={`${base}/app-icon.png`}
			alt="Photo Export app icon"
			class="app-icon"
			width="160"
			height="160"
		/>
		<h1>Photo Export</h1>
		<p class="tagline">
			Free, open-source macOS app to export and back up your iCloud photos to
			any local or external drive, organized by year and month.
		</p>
		<p class="subtitle">
			A native, open-source app. No cloud services, no subscriptions, no account
			required — your photos, your folders.
		</p>
		<div class="hero-actions">
			<span class="btn btn-appstore-soon">Coming soon on the Mac App Store</span
			>
			<a
				href="https://github.com/valtteriluomapareto/vibe-icloud-photo-export/releases"
				class="btn btn-primary">Download from GitHub</a
			>
			<a href={`${base}/getting-started`} class="btn btn-secondary"
				>Get Started</a
			>
			<a
				href="https://github.com/valtteriluomapareto/vibe-icloud-photo-export"
				class="btn btn-secondary"
			>
				View Source
			</a>
		</div>
		<div class="badges">
			<span class="badge">macOS 15+</span>
			<span class="badge">Privacy-first</span>
			<span class="badge">MIT License</span>
			<span class="badge">No Account Required</span>
		</div>
	</div>
</section>

<style>
	.hero {
		background: var(--site-brand-gradient);
		color: white;
		padding: 6rem 2rem 5rem;
		text-align: center;
	}

	.hero-content {
		max-width: 48rem;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.app-icon {
		width: 160px;
		height: 160px;
		border-radius: 28px;
		margin-bottom: 1.5rem;
		filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.3));
	}

	h1 {
		font-size: 3.5rem;
		font-weight: 800;
		margin: 0 0 1rem;
		letter-spacing: -0.02em;
	}

	.tagline {
		font-size: 1.35rem;
		opacity: 0.95;
		margin: 0 0 0.75rem;
		line-height: 1.5;
	}

	.subtitle {
		font-size: 1.05rem;
		opacity: 0.78;
		margin: 0 0 2rem;
		max-width: 40rem;
		margin-inline: auto;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		justify-content: center;
		margin-bottom: 2rem;
		flex-wrap: wrap;
	}

	.badges {
		display: flex;
		gap: 0.5rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.btn-appstore-soon {
		background: rgba(255, 255, 255, 0.1);
		border: 1px solid rgba(255, 255, 255, 0.3);
		cursor: default;
		font-size: 0.95rem;
		opacity: 0.85;
	}

	.badge {
		background: rgba(255, 255, 255, 0.1);
		border: 1px solid rgba(255, 255, 255, 0.2);
		padding: 0.3rem 0.75rem;
		border-radius: 100px;
		font-size: 0.8rem;
		opacity: 0.8;
	}

	@media (max-width: 640px) {
		h1 {
			font-size: 2.5rem;
		}
		.hero {
			padding: 4rem 1.5rem 3rem;
		}
	}
</style>
