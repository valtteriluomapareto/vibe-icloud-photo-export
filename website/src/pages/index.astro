---
import { Image } from 'astro:assets';
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Hero from '../components/Hero.astro';
import FeatureCard from '../components/FeatureCard.astro';
import Footer from '../components/Footer.astro';
import screenshot from '../assets/photo_export_screenshot.png';

const base = import.meta.env.BASE_URL;
const title = 'Photo Export — Free Mac App to Back Up iCloud & Apple Photos';
const description =
	'Free, open-source macOS app to export your iCloud and Apple Photos library to any external drive or local folder. Organized by year/month. No subscription, no cloud services.';

const faqData = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: [
		{
			'@type': 'Question',
			name: 'Does this work with iCloud Photo Library?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Yes. Photo Export reads your Apple Photos library, which includes all photos synced via iCloud. It can also download iCloud originals that are stored remotely on demand during export.',
			},
		},
		{
			'@type': 'Question',
			name: 'Can I export photos to an external hard drive?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Absolutely. You can choose any local or external drive as your export destination. The app remembers your choice across launches.',
			},
		},
		{
			'@type': 'Question',
			name: 'Will it download iCloud originals that are stored remotely?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Yes. During export, the app automatically downloads originals from iCloud when they are not stored locally on your Mac. No manual downloading required.',
			},
		},
		{
			'@type': 'Question',
			name: 'Is Photo Export really free?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Yes. Photo Export is free, open-source software released under the MIT license. No subscriptions, no in-app purchases, no ads.',
			},
		},
		{
			'@type': 'Question',
			name: 'Does it export videos too?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Yes. The app exports photos and videos. Live Photos are exported as a single still image — full motion export (paired image + video) is planned for a future release.',
			},
		},
		{
			'@type': 'Question',
			name: 'What happens if the export is interrupted?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'The app tracks every exported photo. If the export is interrupted, you can resume and it will skip most already-exported files. In rare cases (e.g. a crash mid-write), a file may be copied again.',
			},
		},
	],
};
---

<MarketingLayout title={title} description={description}>
	<script
		type="application/ld+json"
		set:html={JSON.stringify(faqData)}
		slot="head"
	/>
	<Hero />

	<!-- Why Photo Export? -->
	<section class="section" aria-labelledby="why-photo-export">
		<div class="container">
			<h2 id="why-photo-export">
				Why Use Photo Export for Your iCloud Backup?
			</h2>
			<p class="section-lead">
				Photo Export uses Apple's <strong>PhotoKit framework</strong> — the same system
				API that powers the built-in Photos app. It sees exactly what your Photos
				app sees: every photo, video, and album synced through iCloud Photos. No reverse
				engineering, no private APIs, no workarounds.
			</p>
			<p class="section-lead">
				This matters because PhotoKit is <strong>the only supported way</strong> to
				read the Photos library on macOS. It means the app works reliably across macOS
				updates, respects your privacy settings, and can request iCloud originals
				on demand through Apple's own infrastructure. Your credentials never leave
				your Mac.
			</p>
			<div class="value-props">
				<div class="value-prop">
					<strong>Your photos, your folders</strong>
					<span
						>No cloud lock-in. Export originals to any drive you control.</span
					>
				</div>
				<div class="value-prop">
					<strong>Organized automatically</strong>
					<span
						>Photos sorted into a clean <code>Year/Month/</code> folder hierarchy.</span
					>
				</div>
				<div class="value-prop">
					<strong>Only exports new photos</strong>
					<span
						>Skips photos you've already exported. Never creates duplicates.</span
					>
				</div>
				<div class="value-prop">
					<strong>Handles interruptions</strong>
					<span
						>Pause, resume, and recover from interruptions. Individual failures
						don't stop the batch.</span
					>
				</div>
			</div>
		</div>
	</section>

	<!-- Features -->
	<section class="section section-alt" aria-labelledby="features">
		<div class="container">
			<h2 id="features">Features</h2>
			<div class="feature-grid">
				<FeatureCard title="Library Browsing" icon="📸">
					Browse your entire Photos library with a year/month sidebar. See photo
					counts and export status at a glance.
				</FeatureCard>
				<FeatureCard title="Thumbnail Previews" icon="🖼">
					Fast thumbnail grid with in-memory caching. Click any photo for a
					full-size preview.
				</FeatureCard>
				<FeatureCard title="Smart Export Tracking" icon="✅">
					Remembers every exported photo. Resume-safe — never re-exports what's
					already been copied.
				</FeatureCard>
				<FeatureCard title="Pause / Resume / Cancel" icon="⏯">
					Full control over the export queue. Pause a long export and pick it up
					later.
				</FeatureCard>
				<FeatureCard title="Remembers Your Folder" icon="📁">
					Your chosen destination folder is remembered across app launches — no
					need to re-select it.
				</FeatureCard>
				<FeatureCard title="Graceful Error Handling" icon="🛡">
					Handles denied access, unavailable drives, and individual photo
					failures without crashing the batch.
				</FeatureCard>
			</div>
		</div>
	</section>

	<!-- How It Works -->
	<section class="section" aria-labelledby="how-it-works">
		<div class="container">
			<h2 id="how-it-works">How to Export Your iCloud Photos in 3 Steps</h2>
			<p class="section-note">
				<strong>Prerequisite:</strong> Make sure iCloud Photos is enabled on your
				Mac (<strong>System Settings → Apple Account → iCloud → Photos</strong
				>). Photo Export reads your local Photos library, so your iCloud photos
				need to be syncing to this Mac.
			</p>
			<div class="steps">
				<div class="step">
					<div class="step-number">1</div>
					<h3>Grant access & pick a folder</h3>
					<p>
						Authorize Photos library access and choose a destination folder on
						any local or external drive.
					</p>
				</div>
				<div class="step">
					<div class="step-number">2</div>
					<h3>Browse your library</h3>
					<p>
						Navigate by year and month. Preview thumbnails and inspect
						individual photos before exporting.
					</p>
				</div>
				<div class="step">
					<div class="step-number">3</div>
					<h3>Export</h3>
					<p>
						Hit export and the app copies original files into an organized <code
							>Year/Month/</code
						> folder tree. Track progress in real time.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Screenshots -->
	<section class="section section-alt" aria-labelledby="screenshots">
		<div class="container">
			<h2 id="screenshots">Screenshots</h2>
			<div class="screenshot-wrapper">
				<Image
					src={screenshot}
					alt="Photo Export app showing the year/month sidebar, thumbnail grid, and full-size photo preview"
					class="screenshot"
					widths={[600, 900, 1200]}
					sizes="(max-width: 768px) 100vw, 900px"
				/>
			</div>
		</div>
	</section>

	<!-- Installation -->
	<section class="section" aria-labelledby="installation">
		<div class="container">
			<h2 id="installation">Installation</h2>
			<div class="install-steps">
				<ol>
					<li>
						Download the latest <code>.dmg</code> from <a
							href="https://github.com/valtteriluomapareto/vibe-icloud-photo-export/releases"
							>GitHub Releases</a
						>
					</li>
					<li>
						Open the DMG and drag Photo Export to your Applications folder
					</li>
					<li>Launch the app and grant Photos library access when prompted</li>
				</ol>
				<div class="requirements">
					<strong>Requirements:</strong> macOS 15.0+. Signed and notarized by Apple.
				</div>
			</div>
		</div>
	</section>

	<!-- Roadmap -->
	<section class="section section-alt" aria-labelledby="roadmap">
		<div class="container">
			<h2 id="roadmap">Ideas for the future</h2>
			<ul class="roadmap-list">
				<li>Concurrent export pipeline for faster throughput</li>
				<li>iCloud originals handling (download or skip remote-only photos)</li>
				<li>Live Photos and paired media support</li>
				<li>Retry failed exports without restarting the batch</li>
				<li>Media filtering and search within the library browser</li>
				<li>Flexible naming schemes beyond year/month</li>
			</ul>
			<p><a href={`${base}/roadmap`}>See all ideas &rarr;</a></p>
			<p class="feedback-cta">
				Missing a feature? <a
					href="https://github.com/valtteriluomapareto/vibe-icloud-photo-export/issues"
					>Open an issue on GitHub</a
				> and let us know what you need.
			</p>
		</div>
	</section>

	<!-- FAQ -->
	<section class="section" aria-labelledby="faq">
		<div class="container">
			<h2 id="faq">Frequently Asked Questions</h2>
			<dl class="faq-list">
				<div class="faq-item">
					<dt>Does this work with iCloud Photo Library?</dt>
					<dd>
						Yes. Photo Export reads your Apple Photos library, which includes
						all photos synced via iCloud. It can also download iCloud originals
						that are stored remotely on demand during export.
					</dd>
				</div>
				<div class="faq-item">
					<dt>Can I export photos to an external hard drive?</dt>
					<dd>
						Absolutely. You can choose any local or external drive as your
						export destination. The app remembers your choice across launches.
					</dd>
				</div>
				<div class="faq-item">
					<dt>Will it download iCloud originals that are stored remotely?</dt>
					<dd>
						Yes. During export, the app automatically downloads originals from
						iCloud when they aren't stored locally on your Mac. No manual
						downloading required.
					</dd>
				</div>
				<div class="faq-item">
					<dt>Is it really free?</dt>
					<dd>
						Yes. Photo Export is free, open-source software released under the
						MIT license. No subscriptions, no in-app purchases, no ads.
					</dd>
				</div>
				<div class="faq-item">
					<dt>Does it export videos too?</dt>
					<dd>
						Yes. The app exports photos and videos. Live Photos are exported as
						a single still image — full motion export (paired image + video) is
						planned for a future release.
					</dd>
				</div>
				<div class="faq-item">
					<dt>What happens if the export is interrupted?</dt>
					<dd>
						The app tracks every exported photo. If the export is interrupted,
						you can resume and it will skip most already-exported files. In rare
						cases (e.g. a crash mid-write), a file may be copied again.
					</dd>
				</div>
			</dl>
		</div>
	</section>

	<!-- CTA -->
	<section class="section cta-section" aria-labelledby="get-started">
		<div class="container">
			<h2 id="get-started">Get started</h2>
			<p>
				Photo Export is free and open source. Download the app, grant Photos
				access, and start backing up your library today.
			</p>
			<div class="cta-actions">
				<a
					href="https://github.com/valtteriluomapareto/vibe-icloud-photo-export/releases"
					class="btn btn-primary">Download</a
				>
				<a href={`${base}/getting-started`} class="btn btn-secondary"
					>Read the docs</a
				>
				<a
					href="https://github.com/valtteriluomapareto/vibe-icloud-photo-export"
					class="btn btn-secondary"
				>
					View on GitHub
				</a>
			</div>
			<p class="feedback-note">
				Found a bug or have feedback? <a
					href="https://github.com/valtteriluomapareto/vibe-icloud-photo-export/issues"
					>We'd love to hear from you.</a
				>
			</p>
		</div>
	</section>

	<Footer />
</MarketingLayout>

<style>
	.value-props {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
	}

	.value-prop {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.value-prop strong {
		font-size: 1.05rem;
	}

	.section-lead {
		max-width: 40rem;
		margin: 0 auto 1rem;
		color: var(--site-muted);
		font-size: 1rem;
		line-height: 1.7;
		text-align: center;
	}

	.section-lead:last-of-type {
		margin-bottom: 2.5rem;
	}

	.value-prop span {
		color: var(--site-muted);
		font-size: 0.95rem;
	}

	.feature-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.25rem;
	}

	.steps {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
		text-align: center;
		margin-top: 2rem;
	}

	.step-number {
		width: 2.5rem;
		height: 2.5rem;
		background: var(--site-accent);
		color: white;
		border-radius: 50%;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-weight: 700;
		font-size: 1.1rem;
		margin: 0 auto 0.75rem;
	}

	.step h3 {
		font-size: 1.1rem;
		margin-bottom: 0.5rem;
	}

	.step p {
		color: var(--site-muted);
		font-size: 0.95rem;
	}

	.section-note {
		text-align: center;
		color: var(--site-muted);
		font-style: italic;
		max-width: 36rem;
		margin: 0 auto;
	}

	.install-steps h3 {
		font-size: 1.25rem;
		margin-bottom: 0.75rem;
	}

	.install-steps ol {
		margin-left: 1.5rem;
		margin-bottom: 1rem;
	}

	.install-steps li {
		margin-bottom: 0.5rem;
	}

	.requirements {
		background: var(--site-surface-accent);
		border-left: 3px solid var(--site-accent);
		padding: 0.75rem 1rem;
		border-radius: 0 8px 8px 0;
		font-size: 0.95rem;
	}

	.roadmap-list {
		margin-left: 1.5rem;
		margin-bottom: 1rem;
	}

	.roadmap-list li {
		margin-bottom: 0.5rem;
		color: var(--site-muted);
	}

	.feedback-cta {
		text-align: center;
		margin-top: 1.5rem;
		color: var(--site-muted);
		font-size: 0.95rem;
	}

	.feedback-cta a {
		color: var(--site-accent);
		text-decoration: none;
		font-weight: 600;
	}

	.feedback-cta a:hover {
		text-decoration: underline;
	}

	.feedback-note {
		margin-top: 1rem;
		font-size: 0.9rem;
	}

	.feedback-note a {
		color: rgba(255, 255, 255, 0.9);
		text-decoration: underline;
	}

	.cta-section {
		text-align: center;
		background: var(--site-brand-gradient);
		color: white;
	}

	.cta-section h2 {
		color: white;
	}

	.cta-section p {
		opacity: 0.85;
		margin-bottom: 1.5rem;
		font-size: 1.05rem;
	}

	.cta-actions {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.faq-list {
		max-width: 42rem;
		margin: 0 auto;
	}

	.faq-item {
		margin-bottom: 1.5rem;
	}

	.faq-item dt {
		font-weight: 700;
		font-size: 1.05rem;
		margin-bottom: 0.35rem;
	}

	.faq-item dd {
		color: var(--site-muted);
		font-size: 0.95rem;
		margin-left: 0;
		line-height: 1.6;
	}

	.screenshot-wrapper {
		text-align: center;
	}

	.screenshot {
		max-width: 100%;
		height: auto;
		border-radius: 12px;
		box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
	}

	@media (max-width: 768px) {
		.value-props,
		.feature-grid,
		.steps {
			grid-template-columns: 1fr;
		}
	}
</style>
