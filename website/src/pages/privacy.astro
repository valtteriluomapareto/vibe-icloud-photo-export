---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Footer from '../components/Footer.astro';

const title = 'Privacy Policy — Photo Export';
const description =
	'Privacy policy for Photo Export, the macOS app that exports your Apple Photos library to folders you choose.';
const base = import.meta.env.BASE_URL;
---

<MarketingLayout title={title} description={description}>
	<section class="info-page-shell">
		<div class="info-page-card">
			<p class="info-page-kicker">Photo Export</p>
			<h1 class="info-page-title">Privacy Policy</h1>
			<p class="info-page-meta">Last updated: March 30, 2026</p>
			<p class="info-page-lead">
				Photo Export is a local-first macOS app for exporting your Apple Photos
				library to a folder you choose. The app does not run ads, does not use
				third-party analytics, and does not upload your library to our servers.
			</p>

			<section class="info-page-section" aria-labelledby="privacy-summary">
				<h2 id="privacy-summary">Summary</h2>
				<ul class="info-page-list">
					<li>
						We only access your Photos library after you grant macOS permission.
					</li>
					<li>
						We only read and write files in folders that you explicitly choose.
					</li>
					<li>
						Export history and saved folder access are stored locally on your
						Mac.
					</li>
					<li>
						We do not sell, share, or use your photos and videos for advertising
						or profiling.
					</li>
				</ul>
			</section>

			<section class="info-page-section" aria-labelledby="privacy-access">
				<h2 id="privacy-access">What the app can access</h2>
				<p>
					Photo Export requests access to your Photos library so it can list
					assets, show thumbnails and previews, and export originals from Apple
					Photos. If you deny access, the app cannot perform its core job.
				</p>
				<p>
					The app also asks you to choose an export destination folder. On
					macOS, that folder permission is granted by the system file picker and
					is limited to the locations you select.
				</p>
			</section>

			<section class="info-page-section" aria-labelledby="privacy-uses">
				<h2 id="privacy-uses">How the app uses your data</h2>
				<ul class="info-page-list">
					<li>Browse your library by year and month.</li>
					<li>Show thumbnails and full-size previews inside the app.</li>
					<li>
						Export original photos and videos into the folder structure you
						choose.
					</li>
					<li>
						Track which assets were already exported so later runs can skip
						duplicates.
					</li>
					<li>Remember the export destination you selected across launches.</li>
				</ul>
			</section>

			<section class="info-page-section" aria-labelledby="privacy-storage">
				<h2 id="privacy-storage">What is stored locally on your Mac</h2>
				<div class="info-page-grid">
					<div class="info-page-panel">
						<h3>Saved folder access</h3>
						<p>
							The app stores a macOS security-scoped bookmark for the folder you
							selected so it can reopen that same location later without asking
							you every time.
						</p>
					</div>
					<div class="info-page-panel">
						<h3>Export history</h3>
						<p>
							The app stores local export records in your Application Support
							directory so it can resume work and avoid re-exporting files that
							were already copied.
						</p>
					</div>
				</div>
				<p>
					Exported photos and videos are written to the destination folder you
					choose. They remain there until you delete them.
				</p>
			</section>

			<section class="info-page-section" aria-labelledby="privacy-network">
				<h2 id="privacy-network">Network use</h2>
				<p>
					Photo Export does not use third-party analytics, ad networks, or cloud
					sync services operated by this app. If an asset exists only in iCloud,
					macOS and Apple&apos;s PhotoKit framework may fetch the original from
					Apple&apos;s infrastructure during export. Your Apple ID credentials
					are not handled by this app.
				</p>
			</section>

			<section class="info-page-section" aria-labelledby="privacy-sharing">
				<h2 id="privacy-sharing">Sharing</h2>
				<p>
					We do not transmit your photos, videos, export history, or folder
					bookmarks to our servers. We do not sell personal data. We do not
					share your library data with advertisers or analytics providers.
				</p>
			</section>

			<section class="info-page-section" aria-labelledby="privacy-controls">
				<h2 id="privacy-controls">Your controls</h2>
				<ul class="info-page-list">
					<li>
						You can revoke Photos access in <strong
							>System Settings → Privacy &amp; Security → Photos</strong
						>.
					</li>
					<li>
						You can choose a different export destination in the app at any
						time.
					</li>
					<li>
						You can delete exported files from the destination folder whenever
						you want.
					</li>
					<li>
						Local app state remains on your Mac until you remove the app&apos;s
						local data.
					</li>
				</ul>
			</section>

			<section class="info-page-section" aria-labelledby="privacy-contact">
				<h2 id="privacy-contact">Questions</h2>
				<p>
					If you need help, visit the <a href={`${base}/support`}
						>support page</a
					> or open an issue on the <a
						href="https://github.com/valtteriluomapareto/vibe-icloud-photo-export/issues"
						>GitHub issue tracker</a
					>.
				</p>
			</section>
		</div>
	</section>

	<Footer />
</MarketingLayout>
