---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Hero from '../components/Hero.astro';
import FeatureCard from '../components/FeatureCard.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
const title = 'Photo Export - Back up your Apple Photos library';
const description =
	'A native macOS app that exports your Apple Photos library to local or external storage, organized by year and month.';
---

<MarketingLayout title={title} description={description}>
	<Hero />

	<!-- Why Photo Export? -->
	<section class="section" aria-labelledby="why-photo-export">
		<div class="container">
			<h2 id="why-photo-export">Why Photo Export?</h2>
			<div class="value-props">
				<div class="value-prop">
					<strong>Your photos, your folders</strong>
					<span>No cloud lock-in. Export originals to any drive you control.</span>
				</div>
				<div class="value-prop">
					<strong>Organized automatically</strong>
					<span>Assets sorted into a clean <code>Year/Month/</code> folder hierarchy.</span>
				</div>
				<div class="value-prop">
					<strong>Incremental exports</strong>
					<span>Only copies what's new. Never duplicates previously exported files.</span>
				</div>
				<div class="value-prop">
					<strong>Resilient</strong>
					<span>Pause, resume, and recover from interruptions. Individual failures don't stop the batch.</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Features -->
	<section class="section section-alt" aria-labelledby="features">
		<div class="container">
			<h2 id="features">Features</h2>
			<div class="feature-grid">
				<FeatureCard title="Library Browsing" icon="📸">
					Browse your entire Photos library with a year/month sidebar. See asset counts and export status at a glance.
				</FeatureCard>
				<FeatureCard title="Thumbnail Previews" icon="🖼">
					Fast thumbnail grid with in-memory caching. Click any asset for a full-size preview.
				</FeatureCard>
				<FeatureCard title="Smart Export Tracking" icon="✅">
					Tracks every export by asset identifier. Resume-safe — never re-exports what's already been copied.
				</FeatureCard>
				<FeatureCard title="Pause / Resume / Cancel" icon="⏯">
					Full control over the export queue with sidebar controls. Pause a long export and pick it up later.
				</FeatureCard>
				<FeatureCard title="Persistent Folder Access" icon="📁">
					Security-scoped bookmarks remember your chosen destination folder across app launches.
				</FeatureCard>
				<FeatureCard title="Graceful Error Handling" icon="🛡">
					Handles denied access, unavailable drives, and individual asset failures without crashing the batch.
				</FeatureCard>
			</div>
		</div>
	</section>

	<!-- How It Works -->
	<section class="section" aria-labelledby="how-it-works">
		<div class="container">
			<h2 id="how-it-works">How It Works</h2>
			<div class="steps">
				<div class="step">
					<div class="step-number">1</div>
					<h3>Grant access & pick a folder</h3>
					<p>Authorize Photos library access and choose a destination folder on any local or external drive.</p>
				</div>
				<div class="step">
					<div class="step-number">2</div>
					<h3>Browse your library</h3>
					<p>Navigate by year and month. Preview thumbnails and inspect individual assets before exporting.</p>
				</div>
				<div class="step">
					<div class="step-number">3</div>
					<h3>Export</h3>
					<p>Hit export and the app copies original files into an organized <code>Year/Month/</code> folder tree. Track progress in real time.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Screenshots -->
	<section class="section section-alt" aria-labelledby="screenshots">
		<div class="container">
			<h2 id="screenshots">Screenshots</h2>
			<p class="section-note">
				Screenshots coming soon. The app features a sidebar with year/month navigation, a thumbnail grid for browsing photos, full-size asset previews, and export progress controls.
			</p>
		</div>
	</section>

	<!-- Installation -->
	<section class="section" aria-labelledby="installation">
		<div class="container">
			<h2 id="installation">Installation</h2>
			<div class="install-steps">
				<ol>
					<li>Download the latest <code>.dmg</code> from <a href="https://github.com/valtteriluomapareto/vibe-icloud-photo-export/releases">GitHub Releases</a></li>
					<li>Open the DMG and drag Photo Export to your Applications folder</li>
					<li>Launch the app and grant Photos library access when prompted</li>
				</ol>
				<div class="requirements">
					<strong>Requirements:</strong> macOS 15.0+. Signed and notarized by Apple.
				</div>
			</div>
		</div>
	</section>

	<!-- Roadmap -->
	<section class="section section-alt" aria-labelledby="roadmap">
		<div class="container">
			<h2 id="roadmap">Ideas for the future</h2>
			<ul class="roadmap-list">
				<li>Concurrent export pipeline for faster throughput</li>
				<li>iCloud originals handling (download or skip remote-only assets)</li>
				<li>Live Photos and paired asset support</li>
				<li>Retry failed exports without restarting the batch</li>
				<li>Media filtering and search within the library browser</li>
				<li>Flexible naming schemes beyond year/month</li>
			</ul>
			<p><a href={`${base}/roadmap`}>See all ideas &rarr;</a></p>
			<p class="feedback-cta">Missing a feature? <a href="https://github.com/valtteriluomapareto/vibe-icloud-photo-export/issues">Open an issue on GitHub</a> and let us know what you need.</p>
		</div>
	</section>

	<!-- CTA -->
	<section class="section cta-section" aria-labelledby="get-started">
		<div class="container">
			<h2 id="get-started">Get started</h2>
			<p>Photo Export is free and open source. Download the app, grant Photos access, and start backing up your library today.</p>
			<div class="cta-actions">
				<a href="https://github.com/valtteriluomapareto/vibe-icloud-photo-export/releases" class="btn btn-primary">Download</a>
				<a href={`${base}/getting-started`} class="btn btn-secondary">Read the docs</a>
				<a
					href="https://github.com/valtteriluomapareto/vibe-icloud-photo-export"
					class="btn btn-secondary"
				>
					View on GitHub
				</a>
			</div>
			<p class="feedback-note">Found a bug or have feedback? <a href="https://github.com/valtteriluomapareto/vibe-icloud-photo-export/issues">We'd love to hear from you.</a></p>
		</div>
	</section>

	<Footer />
</MarketingLayout>

<style>
	.value-props {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
	}

	.value-prop {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.value-prop strong {
		font-size: 1.05rem;
	}

	.value-prop span {
		color: var(--site-muted);
		font-size: 0.95rem;
	}

	.feature-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.25rem;
	}

	.steps {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
		text-align: center;
	}

	.step-number {
		width: 2.5rem;
		height: 2.5rem;
		background: var(--site-accent);
		color: white;
		border-radius: 50%;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-weight: 700;
		font-size: 1.1rem;
		margin: 0 auto 0.75rem;
	}

	.step h3 {
		font-size: 1.1rem;
		margin-bottom: 0.5rem;
	}

	.step p {
		color: var(--site-muted);
		font-size: 0.95rem;
	}

	.section-note {
		text-align: center;
		color: var(--site-muted);
		font-style: italic;
		max-width: 36rem;
		margin: 0 auto;
	}

	.install-steps h3 {
		font-size: 1.25rem;
		margin-bottom: 0.75rem;
	}

	.install-steps ol {
		margin-left: 1.5rem;
		margin-bottom: 1rem;
	}

	.install-steps li {
		margin-bottom: 0.5rem;
	}

	.requirements {
		background: var(--site-surface-accent);
		border-left: 3px solid var(--site-accent);
		padding: 0.75rem 1rem;
		border-radius: 0 8px 8px 0;
		font-size: 0.95rem;
	}

	.roadmap-list {
		margin-left: 1.5rem;
		margin-bottom: 1rem;
	}

	.roadmap-list li {
		margin-bottom: 0.5rem;
		color: var(--site-muted);
	}

	.feedback-cta {
		text-align: center;
		margin-top: 1.5rem;
		color: var(--site-muted);
		font-size: 0.95rem;
	}

	.feedback-cta a {
		color: var(--site-accent);
		text-decoration: none;
		font-weight: 600;
	}

	.feedback-cta a:hover {
		text-decoration: underline;
	}

	.feedback-note {
		margin-top: 1rem;
		font-size: 0.9rem;
	}

	.feedback-note a {
		color: rgba(255, 255, 255, 0.9);
		text-decoration: underline;
	}

	.cta-section {
		text-align: center;
		background: var(--site-brand-gradient);
		color: white;
	}

	.cta-section h2 {
		color: white;
	}

	.cta-section p {
		opacity: 0.85;
		margin-bottom: 1.5rem;
		font-size: 1.05rem;
	}

	.cta-actions {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	@media (max-width: 768px) {
		.value-props,
		.feature-grid,
		.steps {
			grid-template-columns: 1fr;
		}
	}
</style>
